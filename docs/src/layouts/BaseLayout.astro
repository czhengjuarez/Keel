---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ops Forward Design System',
  description = 'Design system for Ops Forward — a studio practicing design, operations, consulting, and coaching.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Ops Forward</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/mark.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
