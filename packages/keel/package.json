{
  "name": "@ops-forward/keel",
  "version": "0.1.0",
  "description": "Framework-agnostic class utilities for the Keel design system.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css",
    "./ai/component-registry.json": "./src/ai/component-registry.json",
    "./ai/USAGE.md": "./src/ai/USAGE.md"
  },
  "files": [
    "dist",
    "src/styles.css",
    "src/ai",
    "README.md"
  ],
  "sideEffects": [
    "./src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  }
}
